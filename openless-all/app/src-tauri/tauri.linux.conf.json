{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenLess",
        "width": 1240,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "visible": false,
        "acceptFirstMouse": true
      },
      {
        "label": "capsule",
        "url": "index.html?window=capsule",
        "title": "OpenLess Capsule",
        "width": 220,
        "height": 110,
        "decorations": false,
        "transparent": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "center": false,
        "acceptFirstMouse": true
      },
      {
        "label": "qa",
        "url": "index.html?window=qa",
        "title": "OpenLess QA",
        "width": 380,
        "height": 440,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "center": false,
        "acceptFirstMouse": true
      }
    ]
  },
  "bundle": {
    "linux": {
      "deb": {
        "depends": [
          "libasound2",
          "libdbus-1-3",
          "libssl3",
          "libjavascriptcoregtk-4.1-0",
          "libsoup-3.0-0"
        ],
        "recommends": [
          "fcitx5"
        ]
      },
      "rpm": {
        "depends": [
          "alsa-lib",
          "dbus-libs",
          "openssl-libs",
          "webkit2gtk4.1",
          "libsoup3"
        ],
        "recommends": [
          "fcitx5"
        ]
      }
    }
  }
}
